# API key for your LLM provider
# Set the env var that your provider expects (LiteLLM reads these directly):
#   ANTHROPIC_API_KEY=sk-ant-...
#   OPENAI_API_KEY=sk-...
#   OPENROUTER_API_KEY=sk-or-...
#   GEMINI_API_KEY=...
# See https://docs.litellm.ai/docs/providers for the full list.

# Model (LiteLLM format — prefix determines provider routing)
# NOTES2LATEX_MODEL=openrouter/anthropic/claude-sonnet-4-20250514

# Output directory (default: ./output)
# NOTES2LATEX_OUTPUT_DIR=./output
